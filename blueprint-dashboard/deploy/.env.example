# Copy this to `.env` and fill in. .env is git-ignored.

# SSH user on the VPS (must have write access to DEPLOY_PATH)
DEPLOY_USER=deploy

# VPS hostname or IP. Use the direct IP if your DNS is fronted by Cloudflare on a proxied A record (port 22 won't reach the origin).
DEPLOY_HOST=

# Path on the VPS where the dashboard's index.html lives
DEPLOY_PATH=/var/www/rockcreteusa-website-rebuild/

# (Optional) absolute path to a private SSH key. If empty, ssh-agent is used.
DEPLOY_SSH_KEY=

# (Optional) custom SSH port. Defaults to 22.
DEPLOY_SSH_PORT=22

# (Optional) source file to publish. Defaults to ../index.html relative to this folder.
# SOURCE_FILE=

# Public URL for post-deploy verification
URL=https://rockcreteusa.projectizer.ai/
